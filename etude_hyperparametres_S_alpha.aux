\@writefile{toc}{\contentsline {subsection}{\numberline {8.3}Pourquoi MNIST est sensible alors que Digits ne l'est pas : le ratio M/combinaisons}{5}{subsection.8.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Accuracy (\%, 1 run). Forte dégradation (85,9\,\%$\to $39,6\,\%) quand $\alpha $ dépasse $S$ --- contrairement à Digits, quasi plat.}}{6}{table.7}\protected@file@percent }
